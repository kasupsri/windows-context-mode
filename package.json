{
  "name": "context-mode-universal",
  "version": "0.1.0",
  "description": "Cross-platform MCP server that compresses tool outputs, enforces strict safety policies, and tracks token savings.",
  "keywords": [
    "mcp",
    "context-window",
    "compression",
    "cross-platform",
    "macos",
    "linux",
    "powershell",
    "cursor",
    "codex",
    "ai-tools",
    "model-context-protocol"
  ],
  "author": "phanindra208",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-mode-universal": "dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "scripts/",
    "setup.ps1",
    "setup.sh"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:benchmarks": "vitest run --config vitest.bench.config.ts --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "benchmark": "tsx scripts/benchmark.ts",
    "setup": "node dist/index.js setup",
    "doctor": "node dist/index.js doctor",
    "setup:ps1": "powershell -ExecutionPolicy Bypass -File ./setup.ps1",
    "setup:sh": "bash ./setup.sh",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.12.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/emscripten": "^1.41.5",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kasupsri/context-mode-universal.git"
  },
  "bugs": {
    "url": "https://github.com/kasupsri/context-mode-universal/issues"
  },
  "homepage": "https://github.com/kasupsri/context-mode-universal#readme"
}
